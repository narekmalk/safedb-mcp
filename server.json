{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.narekmalk/safedb-mcp",
  "description": "A secure MCP server that lets AI agents query databases safely.",
  "repository": {
    "url": "https://github.com/narekmalk/safedb-mcp",
    "source": "github"
  },
  "version": "0.5.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@safedb/safedb-mcp",
      "version": "0.5.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the service",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YOUR_API_KEY"
        }
      ]
    }
  ]
}
